; Two fibers play ping-pong over a pair of channels.

(def ping-ch (chan))
(def pong-ch (chan))

(spawn (fn []
  (def ping-loop (fn [n]
    (if (> n 0)
      (do
        (send ping-ch "ping")
        (recv pong-ch)
        (ping-loop (- n 1))))))
  (ping-loop 5)
  (send ping-ch "done")))

(def pong-loop (fn []
  (def msg (recv ping-ch))
  (if (= msg "done")
    (println "finished after 5 rounds")
    (do
      (println msg)
      (send pong-ch "pong")
      (pong-loop)))))
(pong-loop)
